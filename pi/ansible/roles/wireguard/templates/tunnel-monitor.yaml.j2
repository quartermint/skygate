# Managed by Ansible - SkyGate Tunnel Monitor
interface: "{{ wg_interface | default('wg0') }}"
check_interval_s: {{ tunnel_monitor_check_interval_s | default(5) }}
handshake_timeout_s: {{ tunnel_monitor_handshake_timeout_s | default(180) }}
recovery_threshold_s: {{ tunnel_monitor_recovery_threshold_s | default(30) }}
fail_count: {{ tunnel_monitor_fail_count | default(3) }}
recover_count: {{ tunnel_monitor_recover_count | default(3) }}
fwmark: "0x2"
table: 200
priority: 200

# SkyGate Remote Server Configuration
# Copy to .env and fill in values

# REQUIRED: Server public IP or domain name
SERVERURL=

# WireGuard port (default: 51820)
SERVERPORT=51820

# Peer names (comma-separated for multi-peer, default: single Pi)
PEERS=skygate-pi

# Internal VPN subnet (default: 10.13.13.0)
INTERNAL_SUBNET=10.13.13.0

# Timezone
TZ=Etc/UTC

# Proxy ports (mapped on wireguard container via network_mode)
# 8443 = Proxy HTTPS listen port
# 8080 = CA cert download + health endpoint
# These are fixed in proxy-config.yaml; change there if needed.
